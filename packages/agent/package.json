{
  "name": "@screenpipe/agent",
  "version": "0.2.0",
  "description": "One-liner to connect OneScreenPI data to your AI agent. Package name stays under @screenpipe/* for compatibility during the rebrand.",
  "type": "module",
  "bin": {
    "screenpipe-agent": "dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "dev": "bun run src/index.ts",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "screenpipe",
    "ai-agent",
    "openclaw",
    
    "memory",
    "morning-summary"
  ],
  "author": "Louis Beaumont <louis@screenpi.pe>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cflev/OneScreenPI",
    "directory": "packages/agent"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
